{
  "manifest_version": 3,
  "name": "ConvertAll",
  "version": "2.0",
  "description": "Scientific Calculator & Unit Converter — all in one",
  "permissions": ["storage", "clipboardRead", "clipboardWrite"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ConvertAll"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'"
  }
}
