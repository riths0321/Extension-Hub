{
  "manifest_version": 3,
  "name": "Extension Manager Pro",
  "version": "2.0.0",
  "description": "A lightweight dashboard to monitor, organize, secure, and control installed Chrome extensions.",
  
  "permissions": [
    "management",
    "storage"
  ],

  "action": {
    "default_title": "Extension Manager Pro",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+E",
        "mac": "Command+Shift+E"
      },
      "description": "Open Extension Manager Pro"
    }
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}