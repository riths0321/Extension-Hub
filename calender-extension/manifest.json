{
  "manifest_version": 3,
  "name": "Calendar & World Clock",
  "description": "Smart calendar with events, holidays, and multi-country world clock with live time.",
  "version": "2.0.0",
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; style-src 'self'; object-src 'none'; connect-src 'self';"
  }
}
