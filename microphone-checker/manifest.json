{
  "manifest_version": 3,
  "name": "Microphone Checker",
  "short_name": "Mic Checker",
  "version": "2.2.0",
  "description": "Test and diagnose your microphone with real-time feedback.",
  "permissions": ["microphone"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Microphone Checker"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
