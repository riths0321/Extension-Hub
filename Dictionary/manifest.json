{
  "name": "Dictionary Search",
  "description": "Quick dictionary lookup via popup",
  "version": "0.0.1",
  "manifest_version": 3,
  "permissions": [],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "logo.png"
    }
  },
  "icons": {
    "16": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; base-uri 'self';"
  }
}
