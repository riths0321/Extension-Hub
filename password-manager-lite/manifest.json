{
  "manifest_version": 3,
  "name": "Password Manager Lite",
  "version": "2.0",
  "description": "Secure, local AES-256 encrypted password manager with auto-fill and beautiful UI.",

  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs",
    "clipboardWrite"
  ],

  "action": {
    "default_title": "Password Manager",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "background": {
    "service_worker": "background.js"
  },

  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "mac": "Command+Shift+P"
      },
      "description": "Open Password Manager"
    }
  },

  "content_scripts": [
    {
      "matches": ["https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "content_security_policy": {
    "extension_pages": "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; object-src 'none'; base-uri 'none';"
  },

  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["https://*/*"]
    }
  ],

  "minimum_chrome_version": "114"
}