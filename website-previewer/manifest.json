{
  "manifest_version": 3,
  "name": "Website Preview Pro",
  "version": "2.3",
  "description": "Preview any website instantly. Dark mode, mobile/desktop views, history, copy screenshot.",
  "permissions": ["tabs", "storage", "clipboardWrite", "clipboardRead"],
  "host_permissions": ["https://image.thum.io/*", "https://www.google.com/*"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}