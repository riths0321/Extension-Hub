{
  "manifest_version": 3,
  "name": "Password Vault Pro",
  "version": "2.0.0",
  "description": "Secure AES-256 encrypted password vault with generator, breach checker, health dashboard, and safe auto-fill.",

  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "alarms",
    "clipboardWrite"
  ],

  "host_permissions": [
    "https://api.pwnedpasswords.com/*"
  ],

  "action": {
    "default_title": "Password Vault Pro",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "background": {
    "service_worker": "background.js"
  },

  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "mac": "Command+Shift+P"
      },
      "description": "Open Password Vault Pro"
    }
  },

  "content_scripts": [
    {
      "matches": ["https://*/*"],
      "exclude_matches": ["https://chrome.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "content_security_policy": {
    "extension_pages": "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; connect-src https://api.pwnedpasswords.com; object-src 'none'; base-uri 'none';"
  },

  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ],

  "minimum_chrome_version": "114"
}