{
  "manifest_version": 3,
  "name": "Quick Image Compressor",
  "version": "1.0",
  "description": "Compress images locally in your browser without uploading.",
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; img-src 'self' data: blob:"
  }
}