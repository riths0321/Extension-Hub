{
  "manifest_version": 3,
  "name": "Tech Detector Pro",
  "description": "Detect technologies powering any website — frontend, backend, CMS, analytics & more",
  "version": "2.0.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tech Detector Pro",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["technologies.json"],
      "matches":   ["<all_urls>"]
    }
  ],
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; style-src 'self'; object-src 'none'; font-src 'self';"
  }
}
