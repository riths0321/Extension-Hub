{
  "manifest_version": 3,
  "name": "Age Calculator",
  "version": "1.2.0",
  "description": "Calculate your exact age instantly.",
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "logo.png",
      "48": "logo.png",
      "128": "logo.png"
    }
  },
  "icons": {
    "16": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  },
  "permissions": ["storage"],
  "content_security_policy": {
     "extension_pages": "script-src 'self'; object-src 'none'; base-uri 'self'"
  }
}