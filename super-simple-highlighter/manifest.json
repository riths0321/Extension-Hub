{
  "manifest_version": 3,
  "name": "Super Simple Highlighter",
  "version": "1.0",
  "description": "Make permanent, private highlights on any web page",

  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "contextMenus"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "content_scripts": [
    {
      "matches":   ["<all_urls>"],
      "js":        ["content.js"],
      "css":       ["styles/highlights.css"],
      "run_at":    "document_idle"
    }
  ],

  "background": {
    "service_worker": "background.js"
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["styles/highlights.css"],
      "matches":   ["<all_urls>"]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },

  "commands": {
    "toggle-highlight": {
      "suggested_key": {
        "default": "Ctrl+Shift+H",
        "mac":     "Command+Shift+H"
      },
      "description": "Toggle highlight mode"
    }
  }
}