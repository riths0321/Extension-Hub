{
  "manifest_version": 3,
  "name": "QuickShot – Screen Capture Tool",
  "version": "3.0.0",
  "description": "Fast screen capture with lightweight annotation and instant export.",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage",
    "downloads",
    "clipboardWrite"
  ],
  "options_page": "option/options.html",
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "QuickShot",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "commands": {
    "capture_visible": {
      "suggested_key": {
        "default": "Alt+Shift+1",
        "mac": "MacCtrl+Shift+1"
      },
      "description": "Capture visible screen"
    },
    "capture_selection": {
      "suggested_key": {
        "default": "Alt+Shift+3",
        "mac": "MacCtrl+Shift+3"
      },
      "description": "Capture selected area"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; base-uri 'self'"
  }
}
