{
  "manifest_version": 3,
  "name": "Email Extractor Pro",
  "version": "2.0.0",
  "description": "Extract email addresses from the current page, copy them quickly, and export results to CSV.",
  "minimum_chrome_version": "88",

  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],

  "action": {
    "default_title": "Email Extractor Pro",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none';"
  }
}
