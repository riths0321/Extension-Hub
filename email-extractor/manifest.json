{
  "manifest_version": 3,
  "name": "Email Extractor Pro",
  "version": "2.0.0",
  "description": "Extract email addresses from the current webpage only after user clicks the extension.",

  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}
