{
  "manifest_version": 3,
  "name": "DataFormat Pro",
  "version": "3.1.0",
  "description": "JSON · XML · YAML · TOML · CSV · HTML — format, validate, convert",
  "permissions": ["storage", "clipboardRead", "clipboardWrite"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "DataFormat Pro"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
