{
  "manifest_version": 3,
  "name": "PDF Previewer Pro",
  "version": "2.0",
  "description": "Advanced PDF previewer with drag & drop, recent files, zoom controls, URL loading, themes, and fullscreen viewer.",

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "permissions": [
    "storage",
    "tabs"
  ],

  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],

  "action": {
    "default_title": "PDF Previewer Pro",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; base-uri 'self'; frame-src 'self' blob:;"
  }
}
