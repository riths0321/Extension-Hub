{
  "manifest_version": 3,
  "name": "CSS Specificity Calculator",
  "version": "2.1.0",
  "description": "Professional CSS selector specificity calculator — live analysis, comparison, history, dark mode.",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "CSS Specificity Calculator"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; base-uri 'self'; img-src 'self'; style-src 'self';"
  }
}